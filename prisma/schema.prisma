datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  image         String?
  phone         String?   // New field for Step 3
  hasCompletedProfile Boolean @default(false)
  predictions   Prediction[]
}

model Prediction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  symptoms  String[]
  results   Json     // Stores the Top 3 array
  createdAt DateTime @default(now())
}